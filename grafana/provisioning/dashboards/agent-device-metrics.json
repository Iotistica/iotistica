        "query": {
          "type": "json",
          "source": "url",
          "url": "/api/v1/grafana/variable/devices",
          "url_options": { "method": "GET", "data": "", "params": "agentId=${agent}" },
          "format": "table",
          "root_selector": "",
          "columns": [
            { "selector": "text", "text": "__text__", "type": "string" },
            { "selector": "value", "text": "__value__", "type": "string" }
          ]
        },
        "current": {}
      },
