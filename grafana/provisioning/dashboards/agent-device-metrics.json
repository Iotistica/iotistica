    },
    {
      "id": 2,
      "title": "Devices under Agent",
      "type": "table",
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "iotistica-infinity" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "device_uuid" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "metric_count" },
            "properties": [{ "id": "displayName", "value": "Metrics" }]
          },
          {
            "matcher": { "id": "byName", "options": "device_name" },
            "properties": [{ "id": "displayName", "value": "Device" }]
          }
        ]
