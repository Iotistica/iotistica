  "title": "Agent Device Metrics",
  "description": "Live telemetry from IoT agents and their devices. Use the variables to drill down by agent, device, and metric.",
  "tags": ["iotistica", "devices", "metrics"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
