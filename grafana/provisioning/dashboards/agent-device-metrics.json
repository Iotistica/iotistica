        "hide": 0,
        "definition": "/api/v1/grafana/variable/metrics",
        "query": {
          "type": "json",
          "source": "url",
          "url": "/api/v1/grafana/variable/metrics",
          "url_options": { "method": "GET", "data": "", "params": "deviceId=${device}&agentId=${agent}" },
          "format": "table",
          "root_selector": "",
          "columns": [
            { "selector": "text", "text": "__text__", "type": "string" },
            { "selector": "value", "text": "__value__", "type": "string" }
          ]
