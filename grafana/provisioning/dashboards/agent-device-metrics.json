        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "definition": "/api/v1/grafana/variable/agents",
        "query": {
          "type": "json",
          "source": "url",
          "url": "/api/v1/grafana/variable/agents",
          "url_options": { "method": "GET", "data": "" },
          "format": "table",
          "root_selector": "",
          "columns": [
            { "selector": "text", "text": "__text__", "type": "string" },
            { "selector": "value", "text": "__value__", "type": "string" }
          ]
        },
        "current": {}
      },
      {
        "name": "device",
        "label": "Device",
        "type": "query",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "iotistica-infinity" },
