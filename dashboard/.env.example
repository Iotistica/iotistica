# Dashboard Environment Variables
# Copy this file to .env.local and configure for your environment

# API URL (optional - auto-detected if not set)
# Local dev: Uses http://localhost:4002 automatically
# Production: Uses window.location.origin automatically
# Override only if you need a custom API URL
# VITE_API_URL=http://localhost:4002

# Examples:
# VITE_API_URL=http://localhost:4002                 # Local development
# VITE_API_URL=https://api.staging.iotistica.com       # Staging API
# VITE_API_URL=https://api.iotistica.com               # Production API

# ============================================================================
# Auth0 Authentication (Required)
# ============================================================================

# Auth0 Application Configuration
# Get these from Auth0 dashboard > Applications > Your App > Settings
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id

# Auth0 Audience - API Identifier (NOT a website URL!)
# This is a unique identifier for your API in Auth0 Dashboard > APIs > Your API > Identifier
# Format looks like a URL but it's just a string identifier for token validation
# Must match AUTH0_AUDIENCE in provisioning service
# ⚠️ This is NOT where users go - it's for JWT validation only
# Example: https://api.iotistica.com (different from website https://iotistic.cloud)
VITE_AUTH0_AUDIENCE=https://api.iotistica.com

# Auth0 Callback URL (where Auth0 redirects after login)
# Must match Application > Allowed Callback URLs in Auth0 dashboard
# For local dev: http://localhost:5173/auth/callback
# For production: https://dashboard.iotistic.cloud/auth/callback
VITE_AUTH0_CALLBACK_URL=http://localhost:8080/auth/callback

# Provisioning API URL (billing service for Auth0 token exchange)
# This is the backend service that handles Auth0 callbacks and customer management
# Local dev: http://localhost:3100
# Production: https://billing.iotistic.cloud
VITE_PROVISIONING_API_URL=http://localhost:3100

# Website URL (for signup completion and marketing pages)
# This is where users are redirected to complete signup after Auth0 authentication
# Local dev: http://localhost:3000
# Production: https://iotistic.cloud
VITE_WEBSITE_URL=http://localhost:3000

# Social Login Providers (optional)
# Set to true to show social login buttons (Google, LinkedIn, GitHub, etc)
VITE_AUTH0_SHOW_SOCIAL_LOGIN=true
