# Dashboard Environment Variables
# Copy this file to .env.local and configure for your environment

# API URL (optional - auto-detected if not set)
# Local dev: Uses http://localhost:4002 automatically
# Production: Uses window.location.origin automatically
# Override only if you need a custom API URL
# VITE_API_URL=http://localhost:4002

# Examples:
# VITE_API_URL=http://localhost:4002                 # Local development
# VITE_API_URL=https://api.staging.iotistic.ca       # Staging API
# VITE_API_URL=https://api.iotistic.ca               # Production API

# ============================================================================
# Auth0 / Multi-Tenant Login Configuration (NEW - Phase 2)
# ============================================================================

# Enable Auth0 login (when true, shows "Login with Auth0" button)
# Set to false for local-only authentication (legacy mode)
VITE_AUTH0_ENABLED=false

# Auth0 Application Configuration
# Get these from Auth0 dashboard > Applications > Your App > Settings
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://api.iotistic.cloud

# Auth0 Callback URL (where Auth0 redirects after login)
# Must match Application > Allowed Callback URLs in Auth0 dashboard
# For local dev: http://localhost:5173/auth/callback
# For production: https://dashboard.iotistic.cloud/auth/callback
VITE_AUTH0_CALLBACK_URL=http://localhost:5173/auth/callback

# Social Login Providers (optional)
# Set to true to show social login buttons (Google, LinkedIn, GitHub, etc)
VITE_AUTH0_SHOW_SOCIAL_LOGIN=true
