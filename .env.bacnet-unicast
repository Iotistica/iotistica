# BACnet Unicast Discovery Configuration
# Use this to test unicast discovery on Docker Desktop Windows

# Discovery targets (comma-separated)
# Since both agent and simulator are on network_mode: host (192.168.65.3),
# target the simulator's IP directly
BACNET_DISCOVERY_TARGETS=192.168.65.3

# Alternative: Subnet sweep (scans 192.168.65.1-254)
# BACNET_DISCOVERY_TARGETS=192.168.65.0/24

# Alternative: IP range
# BACNET_DISCOVERY_TARGETS=192.168.65.1-192.168.65.10

# Alternative: Multiple specific IPs
# BACNET_DISCOVERY_TARGETS=192.168.65.3,192.168.65.4,192.168.65.5
