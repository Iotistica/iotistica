# ============================================================================
# Tailscale VPN Configuration Example
# ============================================================================
# Copy this to your .env file and configure for Tailscale VPN integration
#
# Prerequisites:
# 1. Create Tailscale account at https://tailscale.com
# 2. Generate API key from admin console: Settings → Keys → API Keys
# 3. Note your Tailnet name (shown in admin console)
# ============================================================================

# ----------------------------------------------------------------------------
# VPN Type Selection
# ----------------------------------------------------------------------------
# Options: "wireguard" | "tailscale"
# Default: tailscale
# 
# Set to "wireguard" to use WireGuard for new device provisioning
# Tailscale is recommended for new deployments
VPN_TYPE=tailscale

# ----------------------------------------------------------------------------
# Tailscale Configuration
# ----------------------------------------------------------------------------
# Enable Tailscale VPN service
TAILSCALE_ENABLED=true

# Tailscale API Key (required)
# Get this from: https://login.tailscale.com/admin/settings/keys
# Format: tskey-api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAILSCALE_API_KEY=tskey-api-your-key-here

# Tailnet Name (required)
# Your Tailscale network name (shown in admin console)
# Format: example.com OR user@example.com
# Example: mycompany.com or john@gmail.com
TAILSCALE_TAILNET=example.com

# ----------------------------------------------------------------------------
# WireGuard Configuration (Legacy - Optional)
# ----------------------------------------------------------------------------
# Keep these if you have existing WireGuard devices
# Or if you want to support both VPN types simultaneously
VPN_ENABLED=true
WG_SERVER_URL=http://wg-server:8089
VPN_SERVER_ENDPOINT=vpn.example.com
VPN_SERVER_PORT=51820

# ============================================================================
# Usage Examples
# ============================================================================
#
# Scenario 1: Tailscale Only (Recommended for New Deployments)
# -------------------------------------------------------------
# VPN_TYPE=tailscale
# TAILSCALE_ENABLED=true
# TAILSCALE_API_KEY=tskey-api-xxxxx
# TAILSCALE_TAILNET=mycompany.com
#
# Scenario 2: WireGuard Only (Existing Deployments)
# ---------------------------------------------------
# VPN_TYPE=wireguard  # or omit (default)
# VPN_ENABLED=true
# WG_SERVER_URL=http://wg-server:8089
#
# Scenario 3: Mixed (Gradual Migration)
# --------------------------------------
# VPN_TYPE=tailscale  # New devices use Tailscale
# TAILSCALE_ENABLED=true
# TAILSCALE_API_KEY=tskey-api-xxxxx
# TAILSCALE_TAILNET=mycompany.com
# VPN_ENABLED=true    # Keep for existing WireGuard devices
# WG_SERVER_URL=http://wg-server:8089
#
# ============================================================================
