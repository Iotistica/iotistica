# Iotistic API Environment Configuration

# Server Configuration
PORT=3002
NODE_ENV=development

# JWT Authentication Configuration (REQUIRED)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iotistic
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# Grafana Configuration
GRAFANA_URL=http://localhost:3000
GRAFANA_API_TOKEN=your_grafana_api_token_here

# Docker Configuration
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Optional: Authentication
# API_KEY=your-secret-api-key-here

# License Configuration (from Global Billing API)
LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
LICENSE_JWT=your_license_jwt_from_billing_api

# Global Billing API Integration
BILLING_API_URL=http://localhost:3100
CUSTOMER_ID=cust_your_customer_id_here
INSTANCE_ID=production-1

# Provisioning API Integration (for password reset token validation)
PROVISIONING_API_URL=http://localhost:3100

# Log Retention Configuration
LOG_RETENTION_ENABLED=true
LOG_RETENTION_DAYS=30
LOG_RETENTION_CHECK_HOURS=24
LOG_PARTITION_CHECK_HOURS=720
LOG_COMPRESSION=true

# CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# Include both HTTP and HTTPS variants for production domains
# For K8s fleet deployments calling from different clusters, include the API domain
# Example: https://dashboard.example.com,https://api.example.com,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3000,http://localhost:4002,https://api1.iotistica.com,http://api1.iotistica.com

# Protocol Simulator Configuration
# For Docker Compose: Use container name (default)
# For local debugging: Override with 'localhost'
MODBUS_TCP_HOST=iotistic-modbus-sim

# ============================================================================
# Auth0 / Multi-Tenant RBAC Configuration (NEW - Phase 1 Foundation)
# ============================================================================

# Auth0 Configuration
# Set AUTH0_ENABLED=true to use Auth0 RS256 JWTs (recommended for production)
# Set AUTH0_ENABLED=false to fall back to local HS256 tokens (legacy mode)
AUTH0_ENABLED=false
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.iotistic.cloud
AUTH0_ISSUER=https://your-tenant.auth0.com/

# Provisioning API Configuration (for RBAC cache)
# Used by api service to fetch user roles from billing service
# Format: http://provisioning-service:3100 (internal) or https://billing.example.com (production)
PROVISIONING_API_URL=http://localhost:3100

# Internal Authentication Token (for secure communication with provisioning)
# Generate a strong random token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST match INTERNAL_AUTH_TOKEN in provisioning service
INTERNAL_AUTH_TOKEN=your-internal-auth-token-change-in-production

# MQTT auth hot-path caching (used by /mosquitto-auth/* endpoints)
MQTT_AUTH_CACHE_TTL_SECONDS=30
MQTT_AUTH_DENY_CACHE_TTL_SECONDS=5
MQTT_AUTH_CACHE_MAX_ENTRIES=5000
MQTT_AUTH_LOADER_TIMEOUT_MS=100
MQTT_AUTH_COLD_START_TIMEOUT_MS=500
MQTT_AUTH_COLD_START_WINDOW_SECONDS=30
MQTT_AUTH_CACHE_LOG_HITS=false
MQTT_AUTH_SHARED_CACHE_ENABLED=false
MQTT_AUTH_SHARED_CACHE_EPOCH_REFRESH_SECONDS=2
MQTT_AUTH_SHARED_LOCK_ENABLED=true
MQTT_AUTH_SHARED_LOCK_TIMEOUT_MS=250
MQTT_AUTH_SHARED_LOCK_WAIT_TIMEOUT_MS=125
MQTT_AUTH_SHARED_LOCK_POLL_INTERVAL_MS=15

# RBAC Caching Configuration
RBAC_CACHE_TTL_SECONDS=300

# Tenant Resolution Configuration
# Hostnames are resolved from namespace patterns in the API code.
# Supported labels: customer-{12hex}, client-{12hex}, including service-prefixed
# hostnames such as api-client-{12hex}.example.com.