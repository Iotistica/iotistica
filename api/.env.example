# Iotistic API Environment Configuration

# Server Configuration
PORT=3002
NODE_ENV=development

# JWT Authentication Configuration (REQUIRED)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iotistic
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# Grafana Configuration
GRAFANA_URL=http://localhost:3000
GRAFANA_API_TOKEN=your_grafana_api_token_here

# Docker Configuration
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Optional: Authentication
# API_KEY=your-secret-api-key-here

# License Configuration (from Global Billing API)
LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
LICENSE_JWT=your_license_jwt_from_billing_api

# Global Billing API Integration
BILLING_API_URL=http://localhost:3100
CUSTOMER_ID=cust_your_customer_id_here
INSTANCE_ID=production-1

# Log Retention Configuration
LOG_RETENTION_ENABLED=true
LOG_RETENTION_DAYS=30
LOG_RETENTION_CHECK_HOURS=24
LOG_PARTITION_CHECK_HOURS=720
LOG_COMPRESSION=true

# CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# Include both HTTP and HTTPS variants for production domains
# For K8s fleet deployments calling from different clusters, include the API domain
# Example: https://dashboard.example.com,https://api.example.com,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3000,http://localhost:4002,https://api1.iotistica.com,http://api1.iotistica.com

# Protocol Simulator Configuration
# For Docker Compose: Use container name (default)
# For local debugging: Override with 'localhost'
MODBUS_TCP_HOST=iotistic-modbus-sim

