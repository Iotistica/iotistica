# Secret values for production deployment
# DO NOT COMMIT THIS FILE TO GIT
# Add to .gitignore: values-secret.yaml

# Override MQTT credentials with secure passwords
api:
  mqtt:
    # Option 1: Use Kubernetes Secret (recommended)
    existingSecret: "iotistic-mqtt-credentials"
    
    # Option 2: Override with secure password (less secure)
    # username: admin
    # password: "your-very-secure-password-here"

mqttMonitor:
  mqtt:
    # Option 1: Use Kubernetes Secret (recommended)
    existingSecret: "iotistic-mqtt-credentials"
    
    # Option 2: Override with secure password (less secure)
    # username: admin
    # password: "your-very-secure-password-here"

# Override other sensitive values
postgres:
  password: "change-me-to-secure-postgres-password"

# To deploy with this file:
# helm upgrade --install iotistic ./k8s/charts/iotistic \
#   -f k8s/charts/iotistic/values.yaml \
#   -f k8s/charts/iotistic/values-secret.yaml \
#   -n iotistic-nodeport
