{
  "logging": {
    "level": "info",
    "enableCompression": true,
    "enableRemoteLogging": true,
    "enableFilePersistence": false
  },
  "features": {
    "enableDeviceJobs": true,
    "enableAnomalyDetection": false,
    "enableDeviceRemoteAccess": true,
    "enableDeviceSensorPublish": true
  },
  "settings": {
    "cloudApiEndpoint": "http://localhost:4002",
    "deviceApiPort": 48484,
    "logDir": "/app/data/logs",
    "maxLogs": 10000,
    "logMaxAge": 86400000,
    "maxLogFileSize": 52428800,
    "scheduledRestart": {
      "reason": "heap_fragmentation_cleanup",
      "enabled": true,
      "intervalDays": 7
    },
    "memoryThresholdMb": 30,
    "memoryCheckIntervalMs": 30000,
    "stateReportIntervalMs": 10000
  },
  "intervals": {
    "metricsIntervalMs": 60000,
    "deviceReportIntervalMs": 60000,
    "discoveryFullIntervalMs": 86400000,
    "discoveryLightIntervalMs": 60000,
    "reconciliationIntervalMs": 30000,
    "targetStatePollIntervalMs": 60000
  },
  "protocols": {
    "can": {
      "enabled": false
    },
    "snmp": {
      "port": 161,
      "enabled": false,
      "ipRanges": []
    },
    "comap": {
      "enabled": false
    },
    "opcua": {
      "enabled": false,
      "discoveryUrls": []
    },
    "modbus": {
      "vendor": "Generic",
      "enabled": true,
      "tcpHost": "iotistic-modbus-sim",
      "tcpPort": 502,
      "timeout": 2000,
      "vendorFile": "/app/dist/config/vendors/dataPoints.json",
      "slaveRangeEnd": 10,
      "slaveRangeStart": 1
    }
  }
}