{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"types": ["jest", "node"],
		"isolatedModules": true,
		"rootDir": "..",
		"noEmit": true,
		"module": "CommonJS",
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0"
	},
	"include": [
		"**/*.ts",
		"**/*.spec.ts"
	],
	"exclude": [
		"../node_modules",
		"../dist"
	]
}
