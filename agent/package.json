{
  "name": "device-agent",
  "version": "1.0.507",
  "description": "Standalone device agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy:db-assets",
    "copy:db-assets": "node -e \"const fs=require('fs'); fs.mkdirSync('dist/db',{recursive:true}); fs.copyFileSync('src/db/template.sqlite.sql','dist/db/template.sqlite.sql');\"",
    "copy:pipeline-assets": "node -e \"const fs=require('fs'); fs.cpSync('src/features/pipeline/nr-nodes','dist/features/pipeline/nr-nodes',{recursive:true}); fs.cpSync('src/features/pipeline/flows','dist/features/pipeline/flows',{recursive:true});\"",
    "watch": "tsc --watch",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('protocol-adapters/dist',{recursive:true,force:true});\"",
    "dev": "tsx watch src/app.ts",
    "dev:cloud": "tsx watch src/api/cloud-server.ts",
    "dev:old-api": "tsx watch src/api/server.ts",
    "start": "node --security-revert=CVE-2023-46809 dist/app.js",
    "start:device": "node --security-revert=CVE-2023-46809 dist/app.js",
    "start:cloud": "node --security-revert=CVE-2023-46809 dist/api/cloud-server.js",
    "start:old-api": "node --security-revert=CVE-2023-46809 dist/api/server.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:unit": "jest --config jest.config.unit.js",
    "test:integration": "jest --config jest.config.integration.js",
    "test:watch": "jest --watch",
    "test:watch:unit": "jest --config jest.config.unit.js --watch",
    "test:watch:integration": "jest --config jest.config.integration.js --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:unit": "jest --config jest.config.unit.js --coverage",
    "test:coverage:integration": "jest --config jest.config.integration.js --coverage"
  },
  "keywords": [
    "device-agent",
    "docker",
    "container-orchestration",
    "api"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "bacstack": "^0.0.1-beta.14",
    "better-sqlite3": "^12.4.1",
    "dockerode": "^4.0.2",
    "express": "^4.18.2",
    "modbus-serial": "^8.0.17",
    "mqtt": "^5.14.1",
    "mqtt-pattern": "^2.0.0",
    "msgpack-lite": "^0.1.26",
    "net-snmp": "^3.26.0",
    "node-pty": "^1.0.0",
    "semver": "^7.7.4",
    "systeminformation": "^5.31.6",
    "typed-error": "^3.2.1",
    "undici": "7.24.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dockerode": "^3.3.28",
    "@types/events": "^3.0.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/msgpack-lite": "^0.1.12",
    "@types/net-snmp": "^3.23.0",
    "@types/node": "^22.19.7",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "jest": "^29.0.0",
    "rimraf": "^5.0.10",
    "sinon": "^21.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "node-opcua-client": "^2.130.0"
  },
  "overrides": {
    "tar": "7.5.11",
    "brace-expansion": "5.0.5",
    "jsrsasign": "11.1.1",
    "path-to-regexp": "0.1.13",
    "picomatch": "4.0.4",
    "protobufjs": "7.5.6",
    "@protobufjs/utf8": "1.1.1",
    "ip-address": ">=10.1.1"
  }
}
