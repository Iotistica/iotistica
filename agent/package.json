{
  "name": "device-agent",
  "version": "1.0.402",
  "description": "Standalone device agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy:migrations",
    "copy:migrations": "node -e \"require('fs').cpSync('src/db/migrations', 'dist/db/migrations', {recursive: true})\"",
    "watch": "tsc --watch",
    "clean": "rimraf dist && rimraf protocol-adapters/dist",
    "dev": "tsx watch src/app.ts",
    "dev:cloud": "tsx watch src/api/cloud-server.ts",
    "dev:old-api": "tsx watch src/api/server.ts",
    "dev:livepush": "tsx src/cli/livepush-dev.ts",
    "cli": "tsx cli/iotctl.ts",
    "cli:build": "tsc cli/iotctl.ts --outDir dist/cli --module commonjs --target es2020",
    "start": "node --security-revert=CVE-2023-46809 dist/app.js",
    "start:device": "node --security-revert=CVE-2023-46809 dist/app.js",
    "start:cloud": "node --security-revert=CVE-2023-46809 dist/api/cloud-server.js",
    "start:old-api": "node --security-revert=CVE-2023-46809 dist/api/server.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:unit": "jest --config jest.config.unit.js",
    "test:integration": "jest --config jest.config.integration.js",
    "test:watch": "jest --watch",
    "test:watch:unit": "jest --config jest.config.unit.js --watch",
    "test:watch:integration": "jest --config jest.config.integration.js --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:unit": "jest --config jest.config.unit.js --coverage",
    "test:coverage:integration": "jest --config jest.config.integration.js --coverage"
  },
  "bin": {
    "iotctl": "./dist/cli/iotctl.js"
  },
  "keywords": [
    "device-agent",
    "docker",
    "container-orchestration",
    "api"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@types/mqtt": "^0.0.34",
    "@types/uuid": "^10.0.0",
    "axios": "^1.12.2",
    "bacstack": "^0.0.1-beta.14",
    "better-sqlite3": "^12.4.1",
    "blinking": "^1.0.1",
    "bluebird": "^3.7.2",
    "body-parser": "^1.20.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fp-ts": "^2.16.5",
    "io-ts": "2.2.20",
    "ip": "^2.0.1",
    "knex": "^3.1.0",
    "livepush": "^2.0.0",
    "lodash": "^4.17.21",
    "memoizee": "^0.4.17",
    "modbus-serial": "^8.0.17",
    "mqtt": "^5.14.1",
    "mqtt-pattern": "^2.0.0",
    "msgpack-lite": "^0.1.26",
    "net-snmp": "^3.26.0",
    "network-checker": "^1.0.6",
    "p-limit": "^7.2.0",
    "sqlite3": "^5.1.6",
    "strict-event-emitter-types": "^2.0.0",
    "systeminformation": "^5.23.5",
    "typed-error": "^3.2.1",
    "undici": "^7.18.2",
    "uuid": "^13.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/bluebird": "^3.5.42",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.28",
    "@types/events": "^3.0.3",
    "@types/express": "^4.17.21",
    "@types/ip": "^1.1.3",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.0",
    "@types/memoizee": "^0.4.12",
    "@types/msgpack-lite": "^0.1.12",
    "@types/net-snmp": "^3.23.0",
    "@types/node": "^22.19.7",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^4.0.0",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.0.0",
    "rimraf": "^5.0.10",
    "sinon": "^21.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "node-opcua-client": "^2.130.0"
  }
}
