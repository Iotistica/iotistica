NODE_ENV=production
LOG_LEVEL=info
IOTISTICA_API=https://api.iotistica.com
IOTISTIC_DEVICE_PORT=48484
ORCHESTRATOR_INTERVAL=30000
POLL_INTERVAL_MS=30000
REPORT_INTERVAL_MS=60000
DATABASE_PATH=/var/lib/iotistica/device.sqlite
LOG_DIR=/var/log/iotistica
STATE_FILE=/var/lib/iotistica/target-state.json
