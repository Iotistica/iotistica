  "anomalyDetection": {
    "alerts": {
      "cooldownMs": 300000,
      "maxQueueSize": 1000
    },
    "metrics": [
      {
        "name": "cpu_usage",
        "enabled": true,
        "methods": [
          "zscore",
          "ewma"
        ],
        "threshold": 3,
        "windowSize": 100,
        "expectedRange": [
          0,
          85
        ]
      },
      {
        "name": "memory_percent",
        "enabled": true,
        "methods": [
          "zscore",
          "ewma",
          "rate_change"
        ],
        "threshold": 3,
        "windowSize": 200,
        "expectedRange": [
          0,
          85
        ]
      },
      {
        "name": "cpu_temp",
        "enabled": true,
        "methods": [
          "zscore",
          "mad"
        ],
        "threshold": 3,
        "windowSize": 300,
        "expectedRange": [
          30,
          80
        ]
      }
    ],
    "storage": {
      "retention": 30,
      "minSamples": 5
    },
    "sensitivity": 5,
    "warmupPeriodMs": 900000
  }
}