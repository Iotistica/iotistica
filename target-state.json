        "edge/+",
        "sensor/+/data"
      ],
      "monitorDurationMs": 30000
    },
    "snmp": {
      "port": 161,
      "enabled": true,
      "connections": [
        "10.0.0.60"
      ],
      "bufferCapacity": 131072
    },
    "opcua": {
      "enabled": true,
