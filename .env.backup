# ========================================
# Docker Compose Environment Variables
# ========================================

# ========================================
# PostgreSQL Configuration
# ========================================
POSTGRES_DB=iotistic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ========================================
# API Configuration
# ========================================
PORT=3002
NODE_ENV=development
DB_HOST=postgres
DB_PORT=5432
DB_NAME=iotistic
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20
DB_SSL=false                      
DB_SSL_REJECT_UNAUTHORIZED=false

# External API Port
API_PORT_EXT=4002

# ========================================
# MQTT Configuration
# ========================================
MQTT_BROKER_URL=mqtts://mosquitto:8883
MQTT_TLS_REJECT_UNAUTHORIZED=false
MQTT_USERNAME=admin
MQTT_PASSWORD=iotistic42!
MQTT_PERSIST_TO_DB=true
MQTT_DB_SYNC_INTERVAL=10000

# External MQTT Ports
MOSQUITTO_PORT_EXT=5883
MOSQUITTO_WS_PORT_EXT=59002

# ========================================
# Logging Configuration
# ========================================
LOG_COMPRESSION=true

# ========================================
