# Virtual Agent Configuration (Local Testing with Docker Desktop K8s)

# Kubernetes Configuration
# -------------------------
# Path to kubeconfig file (mounted from host)
KUBECONFIG=/root/.kube/config

# Kubernetes namespace for virtual agents
VIRTUAL_AGENT_NAMESPACE=virtual-agents

# Virtual Agent Container Configuration
# --------------------------------------
# Docker image for virtual agent pods
# Use local build: iotistic/agent:latest
# Or specific version: iotistic/agent:v1.2.3
AGENT_IMAGE=iotistic/agent:latest

# Image pull policy: Always, IfNotPresent, Never
# For local testing with local images: Never or IfNotPresent
# For pulling from registry: Always
AGENT_IMAGE_PULL_POLICY=IfNotPresent

# Virtual Agent Connection URLs
# ------------------------------
# Cloud API URL that virtual agents will connect to
# For local testing, use your host machine's IP or domain
# Examples:
#   - Local API: http://host.docker.internal:4002
#   - Cloud API: https://api1.iotistica.com:443
CLOUD_API_URL=https://api1.iotistica.com:443

# MQTT broker URL for virtual agents
# Examples:
#   - Local MQTT: mqtt://host.docker.internal:5883
#   - Cloud MQTT: mqtts://mqtt1.iotistica.com:8883
MQTT_BROKER_URL_VIRTUAL=mqtts://mqtt1.iotistica.com:8883

# Virtual Agent Resource Limits
# ------------------------------
# CPU limits (Kubernetes format: m = millicores, 1000m = 1 core)
VIRTUAL_AGENT_CPU_REQUEST=200m
VIRTUAL_AGENT_CPU_LIMIT=1000m

# Memory limits (Kubernetes format: Mi = Megabytes, Gi = Gigabytes)
VIRTUAL_AGENT_MEMORY_REQUEST=512Mi
VIRTUAL_AGENT_MEMORY_LIMIT=2Gi

# Docker Desktop K8s Considerations
# ----------------------------------
# Docker Desktop default resources:
#   - CPU: 2 cores (can run ~4 virtual agents at 1000m limit)
#   - Memory: 8 GB (can run ~4 virtual agents at 2Gi limit)
#
# Adjust resources in Docker Desktop Settings > Resources if needed
# For testing, consider reducing limits:
#   VIRTUAL_AGENT_CPU_LIMIT=500m
#   VIRTUAL_AGENT_MEMORY_LIMIT=1Gi
