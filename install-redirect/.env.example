# Install Redirect Service Configuration
# Copy to .env and fill in your values

# Azure Storage Account name (without .blob.core.windows.net)
AZURE_STORAGE_ACCOUNT=your-storage-account

# Azure Storage Container where install.sh is stored
AZURE_STORAGE_CONTAINER=scripts

# Server port (default: 3000)
PORT=3000

# Node environment (production or development)
NODE_ENV=production
