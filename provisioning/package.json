{
  "name": "Iotistica-provisioning",
  "version": "1.0.103",
  "description": "Provisioning - Stripe integration, license management, and subscription control for Iotistica",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "worker": "node dist/worker.js",
    "dev:worker": "ts-node src/worker.ts",
    "clean": "rimraf dist",
    "migrate": "psql $DATABASE_URL -f migrations/001_initial_schema.sql",
    "create-template-db": "node dist/scripts/create-template-db.js",
    "dev:create-template-db": "ts-node src/scripts/create-template-db.ts",
    "create-template": "ts-node scripts/create-template.ts",
    "dev:generate-license": "ts-node src/scripts/generate-license.ts",
    "generate-license": "node dist/scripts/generate-license.js",
    "cleanup:old-vault": "ts-node tools/1password-cleanup-old-vault.ts"
  },
  "keywords": [
    "billing",
    "stripe",
    "saas",
    "licensing"
  ],
  "dependencies": {
    "@1password/sdk": "^0.4.0",
    "@bull-board/api": "^6.13.1",
    "@bull-board/express": "^6.13.1",
    "@types/bull": "^3.15.9",
    "@types/express-rate-limit": "^5.1.3",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.0",
    "pg": "^8.11.3",
    "simple-git": "^3.32.3",
    "stripe": "^14.9.0",
    "uuid": "^9.0.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.22",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "lodash": "^4.18.0",
    "follow-redirects": "^1.16.0",
    "path-to-regexp": "0.1.13",
    "brace-expansion": "^5.0.5"
  }
}
