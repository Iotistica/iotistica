# Server Configuration
PORT=3100
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/Iotistic_billing

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Get this from: docker logs billing-stripe-cli (look for "Ready! Your webhook signing secret is whsec_...")
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product Price IDs (create these in Stripe Dashboard under Products)
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id

# JWT License Signing (RS256 - Use generated keys)
LICENSE_PRIVATE_KEY_PATH=./keys/private-key.pem
LICENSE_PUBLIC_KEY_PATH=./keys/public-key.pem

# License Public Key (for K8s deployments - loaded as string, not path)
# This is injected into customer instances at deploy time
# IMPORTANT: Never commit this to Git! Load from environment in production
LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAqS6oN6f88fM0YkWE1rcu
sUDStDBOnVSFjl2jvSwsb+2jb6dFESj+HJBREmwdtFJp1J9hS8PiNXs3PcsyGJi8
GTYUhpy5Xv7I96A5krmRUfFxJylaS3wmMl55M19f2z0mi8CayhzXgmK3CKA+rLa+
LC+CxpVIFMc88vJxkeC14W8Hh25wxxbXCTTtS702cjtVzDZSWuM/hIqlBAPKDfKo
Tp8otRyNJyutl1wwnF5mI/3sVyNMyEPzVG3H6y/3Kt4BYXyzt9CgMoGHCxLaQNxn
z+kivnIY8PK2Ywii3OFkO47/+ZlV6+e6bny9hlvCkhU9DNfzoBb4YBAu4F62llLK
lQIDAQAB
-----END PUBLIC KEY-----"

# Kubernetes Deployment Configuration (Legacy - Helm Direct)
HELM_CHART_PATH=../charts/customer-instance
BASE_DOMAIN=iotistic.ca
# Set to true to skip actual Helm deployment (local testing)
SIMULATE_K8S_DEPLOYMENT=false

# GitOps Configuration (Replaces Helm Direct)
GITOPS_ENABLED=true
GITOPS_REPO_URL=https://github.com/Iotistica/iot-k8s.git
GITOPS_REPO_DIR=/tmp/iot-k8s-main
GITOPS_MAIN_BRANCH=main
GITOPS_PAT=ghp_xxxxxxxxxxxxxxxxxxxxx
GITOPS_COMMIT_AUTHOR_NAME=IoTistic Billing Bot
GITOPS_COMMIT_AUTHOR_EMAIL=billing@iotistic.com

# Argo CD Status Polling
ARGOCD_BASE_URL=https://cd.iotistica.com
ARGOCD_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ARGOCD_STATUS_MAX_RETRIES=10
ARGOCD_STATUS_RETRY_DELAY_MS=5000
# Set to 'true' to skip Argo CD status check (for testing Git flow only)
# Useful when you don't have Argo CD running yet
SKIP_ARGOCD_STATUS_CHECK=false

# TigerData Configuration (TimescaleDB provisioning)
# Uses HTTP Basic Authentication: base64(access_key:secret_key)
TIGERDATA_API_URL=https://console.cloud.timescale.com/public/api/v1
TIGERDATA_ACCESS_KEY=your_access_key_here
TIGERDATA_SECRET_KEY=your_secret_key_here
TIGERDATA_PROJECT_ID=your_project_id
TIGERDATA_DEFAULT_REGION=us-east-1
TIGERDATA_DEFAULT_PLAN=dev

# 1Password Secrets Automation (using SDK)
# Get service account token from: https://developer.1password.com/docs/service-accounts
# Token should start with "ops_"
# Vault ID: Run 'npx ts-node tests/list-vaults.ts' to get your vault ID (it's a UUID, not the vault name)
ONEPASSWORD_CONNECT_TOKEN=your_service_account_token_here
ONEPASSWORD_VAULT_ID=your_vault_id_here

# Trial Configuration
DEFAULT_TRIAL_DAYS=14

# URLs
BASE_URL=http://localhost:3100
CUSTOMER_PORTAL_URL=http://localhost:3100/portal

# Logging
LOG_LEVEL=info
