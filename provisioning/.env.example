# Server Configuration
PORT=3100
NODE_ENV=development

# URLs
BASE_URL=http://localhost:3100
# Website URL (for Auth0 redirects and signup success pages)
WEBSITE_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/Iotistic_billing

# Redis (for deployment queue)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_CLUSTER=false
# REDIS_TLS=false
# REDIS_USE_TLS=false

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Get this from: docker logs billing-stripe-cli (look for "Ready! Your webhook signing secret is whsec_...")
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product Price IDs (create these in Stripe Dashboard under Products)
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id

# JWT License Signing (RS256 - Use generated keys)
LICENSE_PRIVATE_KEY_PATH=./keys/private-key.pem
LICENSE_PUBLIC_KEY_PATH=./keys/public-key.pem

# License Public Key (for K8s deployments - loaded as string, not path)
# This is injected into customer instances at deploy time
# IMPORTANT: Never commit this to Git! Load from environment in production
