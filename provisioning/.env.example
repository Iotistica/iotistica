# Kubernetes Deployment Configuration (Legacy - Helm Direct)
HELM_CHART_PATH=../charts/customer-instance
BASE_DOMAIN=iotistica.com
# Set to true to skip actual Helm deployment (local testing)
SIMULATE_K8S_DEPLOYMENT=false

# GitOps Configuration (Replaces Helm Direct)
GITOPS_ENABLED=false
GITOPS_REPO_URL=https://github.com/Iotistica/iot-k8s.git
GITOPS_REPO_DIR=/tmp/iot-k8s-main
GITOPS_MAIN_BRANCH=main
# Personal Access Token - Used for both Git commits AND GitHub API (releases)
# Required permissions: repo (full access for private repos)
GITOPS_PAT=ghp_xxxxxxxxxxxxxxxxxxxxx
GITOPS_COMMIT_AUTHOR_NAME=IoTistic Billing Bot
GITOPS_COMMIT_AUTHOR_EMAIL=billing@iotistic.com

# GitHub API Configuration
# Required for accessing private repository releases
# If not set, will fall back to GITOPS_PAT (they can be the same token)
# Generate token at: https://github.com/settings/tokens
# Required permissions: repo (read access to releases)
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Argo CD Status Polling
ARGOCD_BASE_URL=https://cd.iotistica.com
ARGOCD_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ARGOCD_STATUS_MAX_RETRIES=90
ARGOCD_STATUS_RETRY_DELAY_MS=10000
# Continuous monitoring polling interval (milliseconds)
# How often to poll Argo CD for application status updates
MONITOR_POLL_INTERVAL_MS=10000

# TigerData Configuration (TimescaleDB provisioning)
# Uses HTTP Basic Authentication: base64(access_key:secret_key)
TIGERDATA_API_URL=https://console.cloud.timescale.com/public/api/v1
TIGERDATA_ACCESS_KEY=your_access_key_here
TIGERDATA_SECRET_KEY=your_secret_key_here
TIGERDATA_PROJECT_ID=your_project_id
TIGERDATA_DEFAULT_REGION=us-east-1
TIGERDATA_DEFAULT_PLAN=dev

# ============================================================================
# Database Provisioning Provider Selection
# ============================================================================
# PROVISIONING_DB_PROVIDER controls which backend is used to create per-client databases.
#
#   tigerdata  (default) - Managed TimescaleDB via TigerData/Timescale Cloud API.
#                          Requires TIGERDATA_* variables above.
#
#   postgres             - Self-hosted PostgreSQL: runs CREATE DATABASE / CREATE ROLE
#                          directly on the provisioning PostgreSQL server.
#                          Requires PROVISIONING_PG_* variables below.
#
#   cnpg                 - CloudNativePG (Kubernetes-managed PostgreSQL).
#                          No DDL is executed by the provisioning service.
#                          A CNPG Database CR is written to git (picked up by ArgoCD)
#                          and the db-init Helm hook creates the app role on first sync.
#                          Requires CNPG_* variables below.
#
PROVISIONING_DB_PROVIDER=tigerdata

# PostgreSQL Provisioning Configuration (used when PROVISIONING_DB_PROVIDER=postgres)
# The admin credentials must have CREATE DATABASE and CREATE ROLE privileges.
PROVISIONING_PG_HOST=localhost
PROVISIONING_PG_PORT=5432
PROVISIONING_PG_ADMIN_USER=postgres
PROVISIONING_PG_ADMIN_PASSWORD=your_admin_password_here
PROVISIONING_PG_ADMIN_DB=postgres
# Set to 'true' to enable SSL/TLS for the admin connection
PROVISIONING_PG_SSL=false
# When SSL is enabled, set to 'false' only for self-signed certificates in development.
# Leave unset or set to 'true' in production to verify the server certificate.
PROVISIONING_PG_SSL_REJECT_UNAUTHORIZED=true
# Set to 'true' to skip real database operations during local testing
SIMULATE_POSTGRES_PROVISIONING=false
# Optional: name of a pre-schema'd template database that lives on the SAME
# PostgreSQL server (PROVISIONING_PG_HOST).  When set, new client databases are
# cloned from this template at the filesystem level instead of running all
# migration scripts on first startup.  The template is automatically created
# and populated with the full API schema when the provisioning API container
# starts (or manually via: npm run create-template-db).
# Requires admin credentials (PROVISIONING_PG_ADMIN_USER / PROVISIONING_PG_ADMIN_PASSWORD).

# CloudNativePG Configuration (used when PROVISIONING_DB_PROVIDER=cnpg)
# The provisioning service writes a CNPG Database CR to git; ArgoCD deploys it;
# the CNPG operator creates the database. The app role is created by the db-init
# Helm hook on first client ArgoCD sync.
#
# No new env vars required — reuses existing PROVISIONING_PG_HOST / PROVISIONING_PG_PORT
# as the pooler connection endpoint written into app credentials.
# Cluster name, namespace, and DB owner are hardcoded in the service.
# Leave unset to use the standard PostgreSQL default (empty database).
PROVISIONING_PG_TEMPLATE_DB=template_iotistica

# Path to the directory containing the API migration SQL files.
# Defaults to /app/api-migrations inside Docker or ../../api/database/migrations locally.
# API_MIGRATIONS_PATH=/app/api-migrations

# 1Password Secrets Automation (using SDK)
# Get service account token from: https://developer.1password.com/docs/service-accounts
# Token should start with "ops_"
# Vault ID: Run 'npx ts-node tests/list-vaults.ts' to get your vault ID (it's a UUID, not the vault name)
ONEPASSWORD_CONNECT_TOKEN=your_service_account_token_here
ONEPASSWORD_VAULT_ID=your_vault_id_here

# Trial Configuration
DEFAULT_TRIAL_DAYS=14

# ============================================================================
# Auth0 / Multi-Tenant RBAC Configuration (NEW - Phase 1 Foundation)
# ============================================================================

# Auth0 Configuration
# These credentials are used for JWT license validation and API integration
AUTH0_DOMAIN=your-tenant.auth0.com

# Auth0 Audience - API Identifier (NOT a website URL!)
# This is found in Auth0 Dashboard > APIs > Your API > Identifier
# Format looks like a URL but it's just a unique string identifier for JWT validation
# ⚠️ This is NOT where users go - it's for token validation only
# Must match VITE_AUTH0_AUDIENCE in dashboard
# Example: https://api.iotistica.com (different from website https://iotistic.cloud)
AUTH0_AUDIENCE=https://api.iotistica.com

AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_CLIENT_ID=your_auth0_m2m_client_id
AUTH0_CLIENT_SECRET=your_auth0_m2m_client_secret

# API Security Tokens
# Admin API Token - Used for protected admin endpoints (/api/admin/*, /admin/queues, deployment operations)
# This token protects sensitive operations like customer deployment, deletion, and queue management
# Generate with: openssl rand -hex 32 or node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Usage: curl -H "Authorization: Bearer <token>" http://localhost:3100/api/admin/jobs
ADMIN_API_TOKEN=your-admin-api-token-change-in-production

# Internal Authentication Token
# Shared secret for secure service-to-service communication between tenant API and billing API
# This token allows tenant instances to fetch RBAC data and customer status from billing service
# Generate with: openssl rand -hex 32 or node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST match BILLING_INTERNAL_TOKEN in tenant API .env (same value in both services)
# Usage: curl -H "X-Internal-Token: <token>" http://localhost:3100/api/internal/customers/:id/user-role
INTERNAL_AUTH_TOKEN=your-internal-auth-token-change-in-production