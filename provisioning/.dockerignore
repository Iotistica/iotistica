# Node
node_modules
npm-debug.log
.npm

# Build artifacts (will be generated inside Docker)
dist

# Tests
test
tests
*.test.js
*.spec.js
coverage
.nyc_output

# Documentation
*.md
!README.md
docs

# Git (excluding .git saves significant space)
.git
.gitignore
.github

# IDE
.vscode
.idea
*.swp
*.swo

# Environment (secrets should never be in images)
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log

# Scripts (keep only docker-specific files)
scripts
!docker-entrypoint.sh

# Docker files (no need to copy into image)
Dockerfile
docker-compose*.yml
.dockerignore

# Temporary files
temp
tmp
*.tmp

# OS files
.DS_Store
Thumbs.db

# Keys directory (will be mounted as volume)
keys/*.pem
