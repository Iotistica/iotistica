{
  "anomalyDetection": {
    "alerts": {
      "cooldownMs": 300000,
      "maxQueueSize": 1000
    },
    "metrics": [
      {
        "name": "cpu_usage",
        "enabled": true,
        "methods": [
          "zscore",
          "ewma"
        ],
        "threshold": 3,
        "windowSize": 100,
        "expectedRange": [
          0,
          85
        ]
      },
      {
        "name": "memory_percent",
        "enabled": true,
        "methods": [
          "zscore",
          "ewma",
          "rate_change"
        ],
        "threshold": 3,
        "windowSize": 200,
        "expectedRange": [
          0,
          85
        ]
      },
      {
        "name": "cpu_temp",
        "enabled": true,
        "methods": [
          "zscore",
          "mad"
        ],
        "threshold": 3,
        "windowSize": 300,
        "expectedRange": [
          30,
          80
        ]
      }
    ],
    "storage": {
      "retention": 30,
      "minSamples": 5
    },
    "sensitivity": 5
  },
  "logging": {
    "level": "info",
    "maxLogs": 10000,
    "logMaxAge": 86400000,
    "maxLogFileSize": 52428800,
    "enableCompression": true,
    "enableRemoteLogging": true,
    "enableFilePersistence": false
  },
  "runtime": {
    "scheduledRestart": {
      "reason": "heap_fragmentation_cleanup",
      "enabled": true,
      "intervalDays": 7
    },
    "memory":{
      "thresholdMb": 30,
      "checkIntervalMs": 30000
    }
  },
  "features": {
    "enableDeviceJobs": true,
    "enableAnomalyDetection": true,
    "enableDeviceRemoteAccess": true,
    "enableDeviceSensorPublish": true
  },
  "intervals": {
    "device": { 
      "metricsIntervalMs": 60000,
      "reportIntervalMs": 60000,
      "reconciliationIntervalMs": 30000,
      "targetStatePollIntervalMs": 60000
    },
    "discovery": {
      "fullIntervalMs": 86400000,
      "lightIntervalMs": 300000
    }
  },
  "protocols": {
    "can": {
      "enabled": false
    },
    "snmp": {
      "port": 161,
      "enabled": false,
      "ipRanges": []
    },
    "opcua": {
      "enabled": true,
      "discoveryUrls": []
    },
    "modbus": {
      "points": {
        "humidity": {
          "base": 550,
          "type": "holding",
          "unit": "%RH",
          "scale": 0.1,
          "address": 11,
          "dataType": "uint16",
          "noise_pct": 0.1,
          "description": "Relative humidity (scaled ×10, e.g., 550 = 55.0%)"
        },
        "pressure": {
          "base": 1013,
          "type": "holding",
          "unit": "hPa",
          "address": 12,
          "dataType": "uint16",
          "noise_pct": 0.015,
          "description": "Atmospheric pressure in hectopascals (1013 hPa = sea level)"
        },
        "temperature": {
          "base": 230,
          "type": "holding",
          "unit": "°C",
          "scale": 0.1,
          "address": 10,
          "dataType": "uint16",
          "noise_pct": 0.08,
          "description": "Ambient temperature (scaled ×10, e.g., 230 = 23.0°C)"
        },
        "holding_register_0": {
          "base": 200,
          "type": "holding",
          "unit": "count",
          "address": 1,
          "dataType": "uint16",
          "noise_pct": 0.1
        },
        "holding_register_1": {
          "base": 280,
          "type": "holding",
          "unit": "count",
          "address": 2,
          "dataType": "uint16",
          "noise_pct": 0.1
        },
        "holding_register_2": {
          "base": 150,
          "type": "holding",
          "unit": "count",
          "address": 3,
          "dataType": "uint16",
          "noise_pct": 0.15
        }
      },
      "vendor": "Generic",
      "enabled": true,
      "addressing": {
        "slaveRange": {
          "end": 10,
          "start": 1
        }
      },
      "connection": {
        "host": "localhost",
        "port": 502,
        "timeoutMs": 2000
      }
    }
  }
}