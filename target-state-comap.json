{
  "anomalyDetection": {
    "alerts": {
      "cooldownMs": 300000,
      "maxQueueSize": 1000
    },
    "metrics": [
      {
        "name": "cpu_usage",
        "enabled": true,
        "methods": [
          "zscore",
          "ewma"
        ],
        "threshold": 3,
        "windowSize": 100,
        "expectedRange": [
          0,
          85
        ]
      },
      {
        "name": "memory_percent",
        "enabled": true,
        "methods": [
          "zscore",
          "ewma",
          "rate_change"
        ],
        "threshold": 3,
        "windowSize": 200,
        "expectedRange": [
          0,
          85
        ]
      },
      {
        "name": "cpu_temp",
        "enabled": true,
        "methods": [
          "zscore",
          "mad"
        ],
        "threshold": 3,
        "windowSize": 300,
        "expectedRange": [
          30,
          80
        ]
      }
    ],
    "storage": {
      "retention": 30,
      "minSamples": 5
    },
    "sensitivity": 5
  },
  "logging": {
    "level": "info",
    "maxLogs": 10000,
    "logMaxAge": 86400000,
    "maxLogFileSize": 52428800,
    "enableCompression": true,
    "enableRemoteLogging": true,
    "enableFilePersistence": false
  },
  "runtime": {
    "scheduledRestart": {
      "reason": "heap_fragmentation_cleanup",
      "enabled": true,
      "intervalDays": 7
    },
    "memory":{
      "thresholdMb": 30,
      "checkIntervalMs": 30000
    }
  },
  "features": {
    "enableDeviceJobs": true,
    "enableAnomalyDetection": true,
    "enableDeviceRemoteAccess": true,
    "enableDeviceSensorPublish": true
  },
  "intervals": {
    "device": { 
      "metricsIntervalMs": 60000,
      "reportIntervalMs": 60000,
      "reconciliationIntervalMs": 30000,
      "targetStatePollIntervalMs": 60000
    },
    "discovery": {
      "fullIntervalMs": 86400000,
      "lightIntervalMs": 300000
    }
  },
  "protocols": {
    "can": {
      "enabled": false
    },
    "snmp": {
      "port": 161,
      "enabled": false,
      "ipRanges": []
    },
    "opcua": {
      "enabled": true,
      "discoveryUrls": []
    },
    "modbus": {
      "points": {
        "engine_rpm": {
          "base": 1500,
          "type": "holding",
          "unit": "RPM",
          "address": 100,
          "dataType": "uint16",
          "noise_pct": 0.05
        },
        "gen_voltage_a": {
          "base": 230,
          "type": "holding",
          "unit": "V",
          "address": 110,
          "dataType": "uint16",
          "noise_pct": 0.02
        },
        "gen_voltage_b": {
          "base": 230,
          "type": "holding",
          "unit": "V",
          "address": 111,
          "dataType": "uint16",
          "noise_pct": 0.02
        },
        "gen_voltage_c": {
          "base": 230,
          "type": "holding",
          "unit": "V",
          "address": 112,
          "dataType": "uint16",
          "noise_pct": 0.02
        },
        "gen_current_a": {
          "base": 50,
          "type": "holding",
          "unit": "A",
          "address": 120,
          "dataType": "uint16",
          "noise_pct": 0.1
        },
        "gen_current_b": {
          "base": 50,
          "type": "holding",
          "unit": "A",
          "address": 121,
          "dataType": "uint16",
          "noise_pct": 0.1
        },
        "gen_current_c": {
          "base": 50,
          "type": "holding",
          "unit": "A",
          "address": 122,
          "dataType": "uint16",
          "noise_pct": 0.1
        },
        "frequency": {
          "base": 50,
          "type": "holding",
          "unit": "Hz",
          "address": 130,
          "dataType": "uint16",
          "noise_pct": 0.01
        },
        "power_kw": {
          "base": 100,
          "type": "holding",
          "unit": "kW",
          "address": 140,
          "dataType": "uint16",
          "noise_pct": 0.15
        },
        "engine_temp": {
          "base": 85,
          "type": "holding",
          "unit": "°C",
          "address": 150,
          "dataType": "uint16",
          "noise_pct": 0.05
        },
        "fuel_level": {
          "base": 75,
          "type": "holding",
          "unit": "%",
          "address": 160,
          "dataType": "uint16",
          "noise_pct": 0.02
        },
        "alarm_1": {
          "type": "coil",
          "address": 0,
          "dataType": "boolean"
        },
        "alarm_2": {
          "type": "coil",
          "address": 1,
          "dataType": "boolean"
        },
        "alarm_3": {
          "type": "coil",
          "address": 2,
          "dataType": "boolean"
        },
        "alarm_4": {
          "type": "coil",
          "address": 3,
          "dataType": "boolean"
        }
      },
      "vendor": "COMAP",
      "enabled": true,
      "addressing": {
        "slaveRange": {
          "end": 10,
          "start": 1
        }
      },
      "connection": {
        "host": "localhost",
        "port": 502,
        "timeoutMs": 2000
      }
    }
  }
}